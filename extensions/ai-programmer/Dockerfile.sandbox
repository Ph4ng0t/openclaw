FROM node:24-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
  ca-certificates \
  git \
  libssl3 \
  python3 \
  ripgrep \
 && update-ca-certificates \
 && rm -rf /var/lib/apt/lists/*
RUN npm install -g --omit=dev @openai/codex@0.116.0 \
 && CODEX_BIN="$(command -v codex)" \
 && test -n "$CODEX_BIN" \
 && "$CODEX_BIN" --version >/dev/null
WORKDIR /workspace
CMD ["tail", "-f", "/dev/null"]
